{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "noImplicitOverride": true,
    "sourceMap": true,
    "outDir": "dist",
    // "moduleResolution": "node16",
    "paths": {
      "jspanel4": ["./types/jspanel4.d.ts"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "./src",
    "./types/"
  ],
  "exclude": [
    "node_modules",
    ".vite",
    "dist"
  ]
}
