{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "noImplicitOverride": true,
    "sourceMap": true,
    // "baseUrl": ".",
    "outDir": "dist",
    // "moduleResolution": "node16",
    "paths": {
      "jspanel4": ["./types/jspanel"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "src"
, "types"  ],
  "exclude": [
    "node_modules",
    ".vite",
    "dist"
  ]
}
